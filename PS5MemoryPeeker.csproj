<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\ps5-playstation-binary-v3.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="libdebug">
      <HintPath>libdebug.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\ps5-playstation-binary-v3.ico" />
    <Resource Include="Assets\Fonts\*.ttf" />
    <Resource Include="Assets\Progress\*.png" />
    <Content Include="Assets\Sounds\*.mp3">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <None Include="libdebug.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="PS5Debug.bin" Condition="Exists('PS5Debug.bin')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
